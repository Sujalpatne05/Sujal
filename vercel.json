{
  "builds": [
    {
      "src": "aerva-react/package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_MQTT_URL": "wss://aerva.onrender.com"
  }
}
